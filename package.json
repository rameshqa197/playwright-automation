{
  "name": "playwrightautomation",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "test": "npx playwright test",
    "test:headed": "npx playwright test --headed",
    "test:headless": "PLAYWRIGHT_HEADLESS=true npx playwright test",
    "test:chromium": "npx playwright test --project=chromium",
    "test:firefox": "npx playwright test --project=firefox",
    "test:webkit": "npx playwright test --project=webkit",
    "test:mobile": "npx playwright test --project=\"Mobile Chrome\" --project=\"Mobile Safari\"",
    "test:all-browsers": "npx playwright test --project=chromium --project=firefox --project=webkit",
    "test:env": "npx dotenv -e .env -- npx playwright test",
    "test:dev": "npx dotenv -e .env.dev -- npx playwright test",
    "test:staging": "npx dotenv -e .env.staging -- npx playwright test",
    "test:prod": "npx dotenv -e .env.prod -- npx playwright test",
    "regression": "npx playwright test",
    "webTests": "npx playwright test --grep @Web",
    "APITests": "npx playwright test --grep @API",
    "WebRegTest": "npx playwright test --grep \"@Web|@API\"",
    "test:debug": "npx playwright test --debug",
    "test:ui": "npx playwright test --ui",
    "test:slow": "SLOW_MO=1000 npx playwright test --headed",
    "show-report": "npx playwright show-report",
    "AllureReport": "npx playwright test --reporter=line,allure-playwright && npx allure generate allure-results --clean && npx allure serve allure-results",
    "AllureGenerate": "npx allure generate allure-results --clean -o allure-report",
    "AllureServe": "npx allure serve allure-results",
    "AllureOpen": "npx allure open allure-report",
    "clean": "rimraf playwright-report test-results allure-results allure-report",
    "install:browsers": "npx playwright install --with-deps"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "devDependencies": {
    "@cucumber/cucumber": "^12.5.0",
    "@playwright/test": "^1.57.0",
    "@types/cucumber": "^6.0.1",
    "@types/node": "^25.0.3",
    "allure-commandline": "^2.36.0",
    "allure-playwright": "^3.4.5",
    "dotenv-cli": "^11.0.0",
    "expect": "^30.2.0",
    "rimraf": "^6.0.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.3"
  },
  "dependencies": {
    "mysql2": "^3.16.1",
    "winston": "^3.19.0",
    "xlsx": "^0.18.5"
  }
}
